{
  "extends": ["config:recommended"],
  "enabledManagers": ["gomod", "dockerfile"],
  "rangeStrategy": "bump",
  "labels": ["dependencies"],
  "semanticCommits": "enabled",  
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchDatasources": ["golang-version"],
      "groupName": "golang-version-updates"
    },
    {
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["golang", "go"],
      "groupName": "golang-version-updates"
    }
  ],
  "prConcurrentLimit": 5
}
